PROJECT_NAME=AutoAssist AI Backend
VERSION=0.1.0
API_V1_STR=/api/v1
DATABASE_URL="postgresql+psycopg://demo_user:demo_password@demo-host.neon.tech/neondb?sslmode=require&channel_binding=require"

SECRET_KEY="demo_secret_key_for_example_only_1234567890abcdef"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
AI_PROVIDER="openrouter"
AI_USE_FALLBACK=true
OPENROUTER_API_KEY="replace_with_openrouter_api_key"
OPENROUTER_MODEL="google/gemini-2.5-flash"
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_APP_NAME="AutoAssist AI Backend"
OPENROUTER_APP_URL="http://localhost:8000"
GEMINI_API_KEY="replace_with_gemini_api_key"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_TIMEOUT_SECONDS=30
OPENAI_API_KEY="replace_with_openai_api_key"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TIMEOUT_SECONDS=30
ROBOFLOW_API_KEY="replace_with_roboflow_api_key_if_needed"
ROBOFLOW_MODEL_ID="replace_with_roboflow_model_id_if_needed"
ROBOFLOW_TASK_TYPE="classification"
ROBOFLOW_TIMEOUT_SECONDS=30
STRIPE_SECRET_KEY="replace_with_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="replace_with_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="replace_with_stripe_webhook_secret"
STRIPE_CURRENCY="usd"
STRIPE_TIMEOUT_SECONDS=30
PLATFORM_COMMISSION_PERCENTAGE=10
